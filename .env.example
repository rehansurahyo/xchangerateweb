# XChangeRateWeb — Environment Variables

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Encryption (must match XChangeRateAPI ENCRYPTION_KEY) ─────
NEXT_PUBLIC_ENCRYPTION_KEY=your-32-char-encryption-key

# ── XChangeRate API Proxy (server-side only — no NEXT_PUBLIC_) ─
# Production: https://xchangerateapi-fw8t.onrender.com
# Local dev:  http://localhost:4000
XCR_API_BASE_URL=https://xchangerateapi-fw8t.onrender.com

# ── Binance (used by worker, not by Next.js frontend) ─────────
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
USE_TESTNET=false
MOCK_BINANCE_DATA=false

# ── Auth ──────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-secret-here
